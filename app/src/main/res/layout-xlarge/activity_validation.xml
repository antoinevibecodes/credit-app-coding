<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.applications.tinytonwe.drivermodificationappversion2.SendPicture.SendPictureActivity">

    <include
        android:id="@+id/tool_bar"
        layout="@layout/toolbar"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/waitLayout">

            <include
                android:id="@+id/waitCard"
                layout="@layout/wait_card"
                />

            <include
                android:id="@+id/progressbar"
                layout="@layout/progressbar"
                />
        </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/cardDataArea"
        android:layout_weight="0.7"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical">
        <FrameLayout
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <include
                layout="@layout/picture_card"/>

            <include
                android:id="@+id/successCard"
                layout="@layout/success_card"/>

            <include
                android:id="@+id/errorCard"
                layout="@layout/error_card"/>

        </FrameLayout>

    </LinearLayout>



        <LinearLayout
        android:layout_margin="@dimen/activity_margin"
        android:layout_weight="0.3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center">


        <LinearLayout
            android:id="@+id/exit_btn_layout"
            android:layout_weight="0.5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:text="Exit"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="18dp"/>

            <ImageButton
                android:id="@+id/cancelBtn"
                android:layout_gravity="center"
                android:layout_width="95dp"
                android:layout_height="95dp"
                android:text="@string/changePicture"
                android:background="@drawable/image_button_style"
                android:src="@drawable/cancel"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/camera_btn_layout"
            android:layout_weight="0.5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:text="Camera"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="18dp"/>

            <ImageButton
                android:id="@+id/retakeBtn"
                android:elevation="@dimen/button_rest_elevation"
                android:layout_gravity="center"
                android:layout_width="95dp"
                android:layout_height="95dp"
                android:text="@string/changePicture"
                android:background="@drawable/image_button_style"
                android:src="@drawable/camera64px"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/send_btn_layout"
            android:layout_weight="0.5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:text="Send"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="18dp"/>

            <ImageButton
                android:id="@+id/sendBtn"
                android:layout_gravity="center"
                android:layout_width="95dp"
                android:layout_height="95dp"
                android:text="@string/changePicture"
                android:background="@drawable/image_button_style"
                android:src="@drawable/send"/>
        </LinearLayout>


    </LinearLayout>

        </LinearLayout>


    </FrameLayout>

</LinearLayout>
