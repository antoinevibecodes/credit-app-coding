<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            android:id="@+id/tool_bar"
            layout="@layout/toolbar"/>

        <!-- Filter tabs -->
        <LinearLayout
            android:id="@+id/filterRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#f5f5f5">

            <Button
                android:id="@+id/filterAll"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="All"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="#4a90d9"/>

            <Button
                android:id="@+id/filterBirthday"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Birthday"
                android:textSize="12sp"
                android:textColor="#333333"
                android:background="#e0e0e0"/>

            <Button
                android:id="@+id/filterGuest"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Guest"
                android:textSize="12sp"
                android:textColor="#333333"
                android:background="#e0e0e0"/>

            <Button
                android:id="@+id/filterEvent"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Event"
                android:textSize="12sp"
                android:textColor="#333333"
                android:background="#e0e0e0"/>
        </LinearLayout>

        <TextView
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No standard cards configured yet.\nTap + to create one."
            android:textSize="16sp"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/standardCardList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/fabAddCard"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:text="+"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:background="#f39c12"
        android:contentDescription="Add standard card"/>

</RelativeLayout>
