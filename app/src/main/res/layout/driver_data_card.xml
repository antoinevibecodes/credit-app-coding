<?xml version="1.0" encoding="utf-8"?>
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDataTemplate"
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/activity_margin">

       <LinearLayout
           android:gravity="center"
           android:padding="@dimen/activity_padding"
           android:layout_width="match_parent"
           android:layout_height="match_parent"
           android:orientation="vertical">



               <ImageView
                   android:layout_gravity="center"
                   android:layout_width="200dp"
                   android:layout_height="200dp"
                   android:scaleType="fitCenter"
                   android:id="@+id/driverImage"
                   android:src="@drawable/temp_image"/>

            <TableLayout
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:stretchColumns="*">

           <TableRow
               android:gravity="center"
               android:layout_weight="1"
               android:layout_width="match_parent"
               android:layout_height="0dp">
                       <TextView
                           android:gravity="center"
                           android:textSize="20sp"
                           android:textColor="#000000"
                           android:layout_height="match_parent"
                           android:layout_width="match_parent"
                           android:id="@+id/driverIdValue"
                           android:text="@string/driverIdText"/>

                   </TableRow>

                   <TableRow
                       android:gravity="center"
                       android:layout_weight="1"
                       android:layout_width="match_parent"
                       android:layout_height="0dp">

                       <TextView
                           android:textSize="20sp"
                           android:textColor="#000000"
                           android:gravity="center"
                           android:layout_height="match_parent"
                           android:layout_width="match_parent"
                           android:id="@+id/firstNameValue"
                           android:text="@string/firstNameText"/>

                   </TableRow>

                   <TableRow
                       android:gravity="center"
                       android:layout_weight="1"
                       android:layout_width="match_parent"
                       android:layout_height="0dp">

                       <TextView
                           android:textSize="20sp"
                           android:textColor="#000000"
                           android:gravity="center"
                           android:layout_height="match_parent"
                           android:layout_width="match_parent"
                           android:id="@+id/lastNameValue"
                           android:text="@string/lastNameText"/>

                   </TableRow>


                   <TableRow
                       android:gravity="center"
                       android:layout_weight="1"
                       android:layout_width="match_parent"
                       android:layout_height="0dp">

                       <TextView
                           android:textSize="20sp"
                           android:textColor="#000000"
                           android:gravity="center"
                           android:layout_height="match_parent"
                           android:layout_width="match_parent"
                           android:id="@+id/dobValue"
                           android:text="@string/dobText"/>

                   </TableRow>
            </TableLayout>

            <!-- Credit Breakdown -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Credit Breakdown"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"/>

            <TableLayout
                android:id="@+id/creditBreakdownTable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                android:padding="8dp">

                <TableRow android:background="#f5f5f5" android:padding="4dp">
                    <TextView android:text="General" android:textSize="13sp" android:textColor="#666" android:gravity="center"/>
                    <TextView android:text="Food" android:textSize="13sp" android:textColor="#666" android:gravity="center"/>
                    <TextView android:text="Track" android:textSize="13sp" android:textColor="#666" android:gravity="center"/>
                    <TextView android:text="TinyTrack" android:textSize="13sp" android:textColor="#666" android:gravity="center"/>
                    <TextView android:text="Train" android:textSize="13sp" android:textColor="#666" android:gravity="center"/>
                    <TextView android:text="Arcade" android:textSize="13sp" android:textColor="#666" android:gravity="center"/>
                </TableRow>

                <TableRow android:padding="4dp">
                    <TextView android:id="@+id/creditGeneral" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="#27ae60" android:gravity="center"/>
                    <TextView android:id="@+id/creditFood" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="#27ae60" android:gravity="center"/>
                    <TextView android:id="@+id/creditTrafficTrack" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="#27ae60" android:gravity="center"/>
                    <TextView android:id="@+id/creditTinyTrack" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="#27ae60" android:gravity="center"/>
                    <TextView android:id="@+id/creditTrain" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="#27ae60" android:gravity="center"/>
                    <TextView android:id="@+id/creditArcade" android:text="0" android:textSize="16sp" android:textStyle="bold" android:textColor="#27ae60" android:gravity="center"/>
                </TableRow>
            </TableLayout>

            <TextView
                android:id="@+id/creditTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total: 0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:paddingBottom="8dp"/>

           </LinearLayout>


    </androidx.cardview.widget.CardView>
