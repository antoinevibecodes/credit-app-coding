<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical"
    android:stretchColumns="*"
    tools:context="com.applications.tinytonwe.camera_module.DisplayPictures">

    <LinearLayout
        android:padding="5dp"
        android:layout_weight="0.2"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:layout_width="fill_parent">



        <android.support.v7.widget.RecyclerView
            android:id="@+id/my_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>

    <LinearLayout
        android:layout_weight="0.6"
        android:layout_height="0dp"
        android:layout_width="fill_parent">
        <RelativeLayout
            android:layout_height="fill_parent"
            android:layout_width="fill_parent">
            <ImageView
                android:background="#000000"
                android:padding="3dp"
                android:layout_centerInParent="true"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:id="@+id/currentPictureDisplayed"/>
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:background="#000000"
        android:layout_weight="0.2"
        android:orientation="vertical"
        android:layout_height="0dp"
        android:layout_width="fill_parent">

        <TableLayout
            android:layout_span="4"
            android:stretchColumns="*"
            android:gravity="center"
            android:layout_height="fill_parent"
            android:layout_width="fill_parent">

            <TableRow
                android:layout_weight="0.1"
                android:layout_height="fill_parent"
                android:layout_width="fill_parent">

                <TextView
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:text="@string/changePicture"
                    style="@android:style/TextAppearance.Medium"
                    android:textColor="#ffc000"/>

                <TextView
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:text="@string/savePicture"
                    style="@android:style/TextAppearance.Medium"
                    android:textColor="#ffc000"/>

            </TableRow>

            <TableRow
                android:layout_weight="1.5"
                android:layout_height="fill_parent"
                android:layout_width="fill_parent">


                <LinearLayout
                    android:layout_gravity="center"
                    android:layout_weight="0.5"
                    android:gravity="center"
                    android:layout_height="fill_parent"
                    android:layout_width="0dp">

                    <ImageButton
                        android:layout_gravity="center"
                        android:id="@+id/retakePicture"
                        android:layout_height="75dp"
                        android:layout_width="75dp"
                        android:background="@drawable/imagebuttons"
                        android:src="@drawable/camera64px"/>

                </LinearLayout>


                <LinearLayout
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:layout_weight="0.5"
                    android:layout_height="fill_parent"
                    android:layout_width="0dp">

                    <ImageButton
                        android:layout_gravity="center"
                        android:id="@+id/selectPicture"
                        android:layout_height="75dp"
                        android:layout_width="75dp"
                        android:background="@drawable/imagebuttons"
                        android:src="@drawable/tick64px"/>
                </LinearLayout>

            </TableRow>

        </TableLayout>
    </LinearLayout>


</LinearLayout>
