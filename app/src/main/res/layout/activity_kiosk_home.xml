<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/kioskMainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1d1d1d">

    <!-- Hidden exit area: tap 5 times to trigger admin PIN -->
    <View
        android:id="@+id/kioskExitArea"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="start"/>

    <TextView
        android:id="@+id/kioskTapPrompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TAP YOUR CARD"
        android:textSize="48sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/kioskStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Place your card on the device to get started"
        android:textSize="20sp"
        android:textColor="#CCCCCC"
        android:gravity="center"/>
</LinearLayout>
