<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <include
        android:id="@+id/tool_bar"
        layout="@layout/toolbar"/>


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/promptCardsLayout"
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
        <include
            android:id="@+id/promptDriverIdCard"
            layout="@layout/prompt_driver_id_card"
            />

        <include
            android:id="@+id/promptCard"
            layout="@layout/prompt_tap_card"
            />

        </LinearLayout>

        <LinearLayout
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/waitLayout">

            <include
                android:id="@+id/waitCard"
                layout="@layout/wait_card"
                />

            <include
                android:id="@+id/progressbar"
                layout="@layout/progressbar"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/errorCardLayout"
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="400dp">

        <include
            android:id="@+id/errorCard"
            layout="@layout/error_card"
            />

            <ImageButton
                android:layout_marginTop="20dp"
                android:id="@+id/backBtn"
                android:elevation="@dimen/button_rest_elevation"
                android:layout_gravity="center"
                android:layout_width="95dp"
                android:layout_height="95dp"
                android:text="@string/changePicture"
                android:background="@drawable/image_button_style"
                android:src="@drawable/back64px"/>

        </LinearLayout>

        <LinearLayout
            android:visibility="gone"
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
                <LinearLayout
                    android:layout_weight="0.7"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:orientation="vertical">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <include
                            layout="@layout/driver_data_card"/>

                        </FrameLayout>

                </LinearLayout>


            <LinearLayout
                android:layout_margin="@dimen/activity_margin"
                android:layout_weight="0.3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/cameraBtn"
                    android:elevation="@dimen/button_rest_elevation"
                    android:layout_gravity="center"
                    android:layout_width="95dp"
                    android:layout_height="95dp"
                    android:text="@string/changePicture"
                    android:background="@drawable/image_button_style"
                    android:src="@drawable/camera64px"/>

            </LinearLayout>

        </LinearLayout>


    </FrameLayout>

</LinearLayout>
