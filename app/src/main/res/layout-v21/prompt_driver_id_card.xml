<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView
    android:layout_gravity="center"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:padding="8dp"
    android:layout_margin="@dimen/activity_margin">

    <LinearLayout
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <TextView
            android:layout_margin="5dp"
            android:textSize="25sp"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter a Driver ID"/>

        <EditText
            android:layout_margin="5dp"
            android:background="@drawable/driver_id_edittxt_style"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:id="@+id/driverID"
            android:inputType="number"
            android:textAlignment="center"
            android:textSize="25sp"
            android:hint="e.g xxxxx"/>

        <Button
            android:layout_margin="5dp"
            android:id="@+id/sendDriverId"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textSize="25sp"
            android:text="OK"
            android:background="@drawable/send_driver_id_button_style"/>

    </LinearLayout>

</android.support.v7.widget.CardView>