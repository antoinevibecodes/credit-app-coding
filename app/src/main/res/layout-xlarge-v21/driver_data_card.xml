<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView
    android:id="@+id/cardDataTemplate"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="300dp"
    android:layout_margin="10dp">

    <LinearLayout
        android:gravity="center"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">


        <LinearLayout
            android:layout_weight="0.5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:scaleType="fitCenter"
                android:id="@+id/driverImage"
                android:src="@drawable/temp_image"/>

        </LinearLayout>

        <TableLayout
            android:layout_weight="0.5"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:stretchColumns="*">

            <TableRow
                android:layout_weight="1"
                android:layout_width="match_parent"
                android:layout_height="0dp">

                <TextView
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textSize="20sp"
                    android:textColor="#000000"
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:id="@+id/driverIdValue"
                    android:text="0123456789"/>


            </TableRow>

            <TableRow
                android:gravity="center"
                android:layout_weight="1"
                android:layout_width="match_parent"
                android:layout_height="0dp">

                <TextView
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textSize="20sp"
                    android:textColor="#000000"
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:id="@+id/firstNameValue"
                    android:text="@string/firstNameText"/>

            </TableRow>

            <TableRow
                android:gravity="center"
                android:layout_weight="1"
                android:layout_width="match_parent"
                android:layout_height="0dp">

                <TextView
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textSize="20sp"
                    android:textColor="#000000"
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:id="@+id/lastNameValue"
                    android:text="@string/lastNameText"/>

            </TableRow>


            <TableRow
                android:gravity="center"
                android:layout_weight="1"
                android:layout_width="match_parent"
                android:layout_height="0dp">

                <TextView
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:textSize="20sp"
                    android:textColor="#000000"
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:id="@+id/dobValue"
                    android:text="@string/dobText"/>

            </TableRow>


        </TableLayout>

    </LinearLayout>


</android.support.v7.widget.CardView>
