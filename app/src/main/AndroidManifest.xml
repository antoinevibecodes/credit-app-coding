<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.applications.tinytonwe.drivermodificationappversion2" >

    <uses-permission android:name="android.permission.NFC" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme" >
        <activity
            android:name=".Main.MainActivity"
            android:label="@string/app_name"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
            </intent-filter>

            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
        </activity>
        <activity
            android:name=".Camera.CameraActivity"
            android:label="@string/title_activity_camera"
            android:noHistory="true"
            android:launchMode="singleTask">
        </activity>
        <activity
            android:name=".SendPicture.SendPictureActivity"
            android:label="@string/title_activity_validation"
            android:noHistory="true"
            android:parentActivityName="com.applications.tinytonwe.drivermodificationappversion2.Main.MainActivity" >

            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.applications.tinytonwe.drivermodificationappversion2.Main.MainActivity" />
        </activity>
        <activity
            android:name=".SelectOption.OptionsActivity"
            android:label="@string/title_activity_options"
            android:parentActivityName="com.applications.tinytonwe.drivermodificationappversion2.Main.MainActivity"
            android:launchMode="singleTask">

            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.applications.tinytonwe.drivermodificationappversion2.Main.MainActivity" />
        </activity>
        <activity
            android:name=".ProcessCredits.ProcessCreditsActivity"
            android:label="@string/title_activity_process_credits"
            android:launchMode="singleTop"
            android:parentActivityName="com.applications.tinytonwe.drivermodificationappversion2.Main.MainActivity" >

            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.applications.tinytonwe.drivermodificationappversion2.Main.MainActivity" />
        </activity>
    </application>

</manifest>
